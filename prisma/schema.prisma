// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Usuários do sistema (multi-tenant) ───────────────────────────
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  phone           String?
  avatar          String?
  passwordHash    String
  role            UserRole  @default(ADMIN)
  plan            PlanType  @default(STARTER)
  planExpiresAt   DateTime?
  emailVerified   Boolean   @default(false)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  refreshToken    String?
  resetToken      String?
  resetTokenExp   DateTime?

  // Dados da empresa/imobiliária
  companyName     String?
  companyEmail    String?
  companyPhone    String?
  companyStreet   String?
  companyNumber   String?
  companyComplement String?
  companyNeighborhood String?
  companyCity     String?
  companyState    String?
  companyZipCode  String?
  creciNumber     String?
  creciState      String?
  logo            String?
  primaryColor    String?

  // Configurações
  whatsappEnabled       Boolean @default(false)
  whatsappApiUrl        String?
  whatsappApiKey        String?
  whatsappInstanceName  String?
  emailNotifications    Boolean @default(true)
  autoChargeEnabled     Boolean @default(false)
  autoChargeDay         Int     @default(5)
  lateFeePercentage     Float   @default(2.0)
  interestPercentage    Float   @default(1.0)

  // Relações
  properties    Property[]
  owners        Owner[]
  tenants       Tenant[]
  contracts     Contract[]
  charges       Charge[]
  documents     Document[]
  historyLogs   HistoryLog[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum PlanType {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ─── Proprietários de imóveis ─────────────────────────────────────
model Owner {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  email     String
  phone     String
  whatsapp  String?
  cpfCnpj   String
  rg        String?

  // Endereço
  street        String?
  number        String?
  complement    String?
  neighborhood  String?
  city          String?
  state         String?
  zipCode       String?

  // Dados bancários
  bankName      String?
  bankAgency    String?
  bankAccount   String?
  bankAccountType BankAccountType?
  pixKey        String?

  status    OwnerStatus @default(ACTIVE)
  notes     String?

  properties Property[]
  contracts  Contract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([cpfCnpj])
  @@index([email])
}

enum OwnerStatus {
  ACTIVE
  INACTIVE
}

enum BankAccountType {
  CHECKING
  SAVINGS
}

// ─── Inquilinos ───────────────────────────────────────────────────
model Tenant {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  email     String
  phone     String
  whatsapp  String?
  cpf       String
  rg        String?
  dateOfBirth   DateTime?
  maritalStatus MaritalStatus?
  profession    String?
  income        Float?

  // Endereço
  street        String?
  number        String?
  complement    String?
  neighborhood  String?
  city          String?
  state         String?
  zipCode       String?

  // Contato de emergência
  emergencyName         String?
  emergencyPhone        String?
  emergencyRelationship String?

  status    TenantStatus @default(ACTIVE)
  notes     String?

  contracts Contract[]
  charges   Charge[]
  documents Document[]   @relation("TenantDocuments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([cpf])
  @@index([email])
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  PENDING
}

enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
}

// ─── Imóveis ──────────────────────────────────────────────────────
model Property {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownerId   String
  owner     Owner          @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  title     String
  type      PropertyType
  status    PropertyStatus @default(AVAILABLE)

  // Endereço
  street        String
  number        String
  complement    String?
  neighborhood  String
  city          String
  state         String
  zipCode       String

  // Características
  bedrooms      Int       @default(0)
  bathrooms     Int       @default(0)
  parkingSpaces Int       @default(0)
  area          Float     @default(0)

  // Valores
  rentValue     Float
  condoFee      Float?
  iptu          Float?

  description   String?
  amenities     String[]  @default([])
  images        String[]  @default([])

  contracts Contract[]
  charges   Charge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([ownerId])
  @@index([status])
  @@index([city, state])
}

enum PropertyType {
  APARTMENT
  HOUSE
  COMMERCIAL
  LAND
  STUDIO
}

enum PropertyStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  INACTIVE
}

// ─── Contratos ────────────────────────────────────────────────────
model Contract {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenantId   String
  tenant     Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ownerId    String
  owner      Owner          @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  startDate       DateTime
  endDate         DateTime
  rentValue       Float
  condoFee        Float?
  iptu            Float?
  depositValue    Float       @default(0)
  depositType     DepositType @default(CASH)
  paymentDay      Int         @default(5)
  readjustmentIndex ReadjustmentIndex @default(IGPM)
  readjustmentMonth Int       @default(12)

  status    ContractStatus @default(PENDING)

  clauses   ContractClause[]
  charges   Charge[]
  documents Document[]      @relation("ContractDocuments")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([propertyId])
  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@index([endDate])
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

enum DepositType {
  CASH
  BANK_GUARANTEE
  INSURANCE
}

enum ReadjustmentIndex {
  IGPM
  IPCA
  INPC
}

// ─── Cláusulas de contrato ────────────────────────────────────────
model ContractClause {
  id         String   @id @default(cuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  title      String
  content    String
  order      Int      @default(0)

  createdAt DateTime @default(now())

  @@index([contractId])
}

// ─── Cobranças ────────────────────────────────────────────────────
model Charge {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractId  String
  contract    Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  tenantId    String
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propertyId  String
  property    Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  type          ChargeType
  description   String
  value         Float
  dueDate       DateTime
  paymentDate   DateTime?
  status        ChargeStatus @default(PENDING)
  paymentMethod PaymentMethod?
  penaltyValue  Float?
  interestValue Float?
  discountValue Float?
  notes         String?

  // WhatsApp tracking
  whatsappSent    Boolean   @default(false)
  whatsappSentAt  DateTime?
  whatsappMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([contractId])
  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
  @@index([dueDate])
}

enum ChargeType {
  RENT
  CONDO_FEE
  IPTU
  WATER
  ELECTRICITY
  GAS
  OTHER
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  PIX
  BOLETO
  TRANSFER
  CASH
  CREDIT_CARD
}

// ─── Documentos ───────────────────────────────────────────────────
model Document {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  type      DocumentType
  url       String
  size      Int          @default(0)
  mimeType  String       @default("application/octet-stream")

  // Relação polimórfica
  tenantId   String?
  tenant     Tenant?   @relation("TenantDocuments", fields: [tenantId], references: [id], onDelete: SetNull)
  contractId String?
  contract   Contract? @relation("ContractDocuments", fields: [contractId], references: [id], onDelete: SetNull)

  uploadedAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([contractId])
  @@index([type])
}

enum DocumentType {
  CONTRACT
  ID_DOCUMENT
  PROOF_INCOME
  PROOF_ADDRESS
  PHOTO
  OTHER
}

// ─── Histórico de alterações (audit log) ──────────────────────────
model HistoryLog {
  id         String          @id @default(cuid())
  userId     String
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  entityType HistoryEntityType
  entityId   String
  action     HistoryAction
  description String
  oldValues  Json?
  newValues  Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

enum HistoryEntityType {
  PROPERTY
  TENANT
  OWNER
  CONTRACT
  CHARGE
  DOCUMENT
  USER
}

enum HistoryAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
}

// ─── Notificações ─────────────────────────────────────────────────
model Notification {
  id      String           @id @default(cuid())
  userId  String
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  message String
  type    NotificationType @default(INFO)
  read    Boolean          @default(false)
  link    String?

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

// ─── Mensagens WhatsApp (log) ─────────────────────────────────────
model WhatsappMessage {
  id          String   @id @default(cuid())
  userId      String
  phone       String
  message     String
  templateName String?
  status      WhatsappMessageStatus @default(QUEUED)
  externalId  String?
  errorMessage String?
  chargeId    String?

  sentAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([chargeId])
  @@index([status])
}

enum WhatsappMessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

// ─── Admin do Sistema (superusuários do SaaS) ────────────────────
model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// ─── Planos de Assinatura (gerenciados pelo admin) ────────────────
model SubscriptionPlan {
  id            String    @id @default(cuid())
  name          String    @unique
  slug          String    @unique
  description   String?
  price         Float
  billingCycle  BillingCycle @default(MONTHLY)
  isActive      Boolean   @default(true)
  isPopular     Boolean   @default(false)
  sortOrder     Int       @default(0)

  // Limites do plano
  maxProperties   Int     @default(10)
  maxTenants      Int     @default(10)
  maxOwners       Int     @default(10)
  maxContracts    Int     @default(10)
  maxUsers        Int     @default(1)

  // Features (JSON para flexibilidade)
  features      String[]  @default([])

  // Stripe
  stripeProductId  String?
  stripePriceId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([isActive])
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

// ─── Configurações do Sistema (singleton-like, key-value) ─────────
model SystemSettings {
  id    String @id @default("system")
  key   String @unique
  value String
  type  String @default("string") // string, number, boolean, json

  updatedAt DateTime @updatedAt

  @@index([key])
}

// ─── Log de Pagamentos (assinaturas dos clientes) ─────────────────
model PaymentLog {
  id            String        @id @default(cuid())
  userId        String
  amount        Float
  currency      String        @default("BRL")
  status        PaymentStatus @default(PENDING)
  paymentMethod String?
  stripePaymentId   String?
  stripeInvoiceId   String?
  description   String?
  periodStart   DateTime?
  periodEnd     DateTime?
  failReason    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

enum PaymentStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}