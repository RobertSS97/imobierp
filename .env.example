# ─── Banco de Dados (PostgreSQL) ──────────────────────────────────
DATABASE_URL=postgresql://imobierp:imobierp_secret_2024@localhost:5432/imobierp?schema=public

# ─── JWT Secrets (OBRIGATÓRIO - gere valores aleatórios seguros) ──
JWT_SECRET=gere-uma-chave-segura-com-openssl-rand-hex-64
JWT_REFRESH_SECRET=gere-outra-chave-segura-com-openssl-rand-hex-64

# ─── Admin Dashboard ─────────────────────────────────────────────
ADMIN_JWT_SECRET=gere-mais-uma-chave-segura-com-openssl-rand-hex-64
ADMIN_EMAIL=admin@imobierp.com
ADMIN_PASSWORD=Admin@2024!
ADMIN_NAME=Robert

# ─── CORS (origens permitidas, separadas por vírgula) ────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── Cron Secret (para jobs agendados) ───────────────────────────
CRON_SECRET=gere-um-secret-para-cron-jobs

# ─── NextAuth ────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=gere-um-nextauth-secret

# ─── API URL (para o frontend conectar no backend) ──────────────
NEXT_PUBLIC_API_URL=/api

# ─── PostgreSQL (docker-compose) ─────────────────────────────────
POSTGRES_USER=imobierp
POSTGRES_PASSWORD=imobierp_secret_2024
POSTGRES_DB=imobierp

# ─── Stripe (pagamentos - opcional) ──────────────────────────────
